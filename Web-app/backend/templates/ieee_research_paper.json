        {"name": "I. Introduction", "style": "HEADING_1", "required": true},
        {"name": "II. Related Work", "style": "HEADING_1", "required": false},
        {"name": "III. Methodology", "style": "HEADING_1", "required": true},
        {"name": "IV. Experimental Setup", "style": "HEADING_1", "required": false},
        {"name": "V. Results and Discussion", "style": "HEADING_1", "required": true},
        {"name": "VI. Conclusion", "style": "HEADING_1", "required": true},
        {"name": "VII. Future Work", "style": "HEADING_1", "required": false},
        {"name": "VIII. Acknowledgments", "style": "HEADING_1", "required": false},
        {"name": "References", "style": "HEADING_1", "required": true}
