{
  "manifest_version": 3,
  "name": "Amarika Formatter",
  "version": "1.0",
  "description": "Automatically format pasted AI-generated content in Google Docs.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["contentScript.js"]
    }
  ]
}
